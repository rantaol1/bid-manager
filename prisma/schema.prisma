generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  industry      String?
  country       String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  notes         String?
  opportunities Opportunity[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String
}

model Opportunity {
  id             String        @id @default(cuid())
  name           String
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  stage          String        @default("lead")
  expectedValue  Decimal?      @db.Decimal(12, 2)
  currency       String        @default("EUR")
  probability    Int?
  closeDate      DateTime?
  tags           String[]
  notes          String?
  teamMembers    TeamMember[]
  scope          Scope?
  rollouts       Rollout[]
  roleConfigs    RoleConfig[]
  timelineConfig Json?
  deliverables   Deliverable[]
  activities     Activity[]
  proposalContent ProposalContent?
  estimationRevisions EstimationRevision[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  createdBy      String

  @@index([customerId])
  @@index([stage])
  @@index([createdBy])
}

model TeamMember {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  userId        String
  userName      String
  userEmail     String?
  role          String

  @@unique([opportunityId, userId])
  @@index([userId])
}

model Scope {
  id            String      @id @default(cuid())
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  modules       Json        @default("{}")
  scopePhases   Json        @default("[]")
  requirements  Json        @default("[]")
  assumptions   String[]
  exclusions    String[]
  deferred      String[]
  risks         Json        @default("[]")
  updatedAt     DateTime    @updatedAt
}

model RoleConfig {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  roleName      String
  rate          Decimal     @db.Decimal(10, 2)
  costRate      Decimal     @db.Decimal(10, 2) @default(0)
  rateUnit      String      @default("day")
  hoursPerDay   Int         @default(8)
  sortOrder     Int         @default(0)

  @@unique([opportunityId, roleName])
  @@index([opportunityId])
}

model Rollout {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  name          String
  colour        String      @default("#E87722")
  sortOrder     Int         @default(0)
  phases        Phase[]

  @@index([opportunityId])
}

model Phase {
  id          String       @id @default(cuid())
  rolloutId   String
  rollout     Rollout      @relation(fields: [rolloutId], references: [id], onDelete: Cascade)
  name        String
  colour      String?
  startDate   DateTime
  endDate     DateTime
  workingDays Int
  sortOrder   Int          @default(0)
  goLives     DateTime[]
  allocations Allocation[]

  @@index([rolloutId])
}

model Allocation {
  id           String  @id @default(cuid())
  phaseId      String
  phase        Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  roleConfigId String
  percentage   Decimal @db.Decimal(5, 2)

  @@unique([phaseId, roleConfigId])
  @@index([phaseId])
}

/// A named, self-contained JSON snapshot of an opportunity's estimation working copy
/// (roles, rollouts, phases, allocations). Restoring overwrites the live tables. Kept
/// roleName-keyed in `snapshot` so it survives regenerated cuids on restore.
model EstimationRevision {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  label         String
  snapshot      Json
  summary       Json?
  kind          String      @default("manual")
  note          String?
  createdAt     DateTime    @default(now())
  createdBy     String
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
}

model Deliverable {
  id             String               @id @default(cuid())
  opportunityId  String
  opportunity    Opportunity          @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  name           String
  type           String
  description    String?
  currentVersion Int                  @default(1)
  versions       DeliverableVersion[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdBy      String

  @@index([opportunityId])
}

model DeliverableVersion {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  version       Int
  fileUrl       String
  fileName      String
  fileSize      Int
  mimeType      String
  changeSummary String?
  createdAt     DateTime    @default(now())
  createdBy     String

  @@index([deliverableId])
}

model Activity {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type          String
  description   String
  metadata      Json?
  createdAt     DateTime    @default(now())
  createdBy     String

  @@index([opportunityId])
  @@index([createdAt])
}

model DefaultRoleConfig {
  id          String  @id @default(cuid())
  roleName    String  @unique
  rate        Decimal @db.Decimal(10, 2)
  costRate    Decimal @db.Decimal(10, 2) @default(0)
  rateUnit    String  @default("day")
  hoursPerDay Int     @default(8)
  sortOrder   Int     @default(0)
}

/// Per-opportunity proposal content. Narrative fields are entered by the user;
/// structured blocks (raci, crims, methodology, etc.) are overrides — when null,
/// the generator falls back to the global ProposalDefaults singleton.
model ProposalContent {
  id            String      @id @default(cuid())
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  // Narrative (manual entry)
  executiveSummary Json?
  understanding    String?
  valueDrivers     Json?
  commercialModel  String?
  recommendation   String?
  teamProfiles     Json?
  references       Json?
  contactName      String?
  contactTitle     String?
  contactEmail     String?
  contactPhone     String?

  // Structured overrides (null => use global default)
  raci                Json?
  crims               Json?
  methodologyPhases   Json?
  waysOfWorking       Json?
  governance          Json?
  teamStructure       Json?
  customerCommitments Json?
  dataMigrationSteps  Json?
  integrationSteps    Json?
  testingSteps        Json?
  adoptionSteps       Json?
  goLiveSteps         Json?
  whyArcwide          Json?

  // Chosen deck-template version per output kind (null => workspace default deck).
  fullDeckVersionId  String?
  fullDeckVersion    DeckTemplateVersion? @relation("FullDeckSelection", fields: [fullDeckVersionId], references: [id], onDelete: SetNull)
  boardDeckVersionId String?
  boardDeckVersion   DeckTemplateVersion? @relation("BoardDeckSelection", fields: [boardDeckVersionId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt
}

/// Uploaded document templates. `docx_template` files contain {placeholders} filled
/// via docxtemplater; `text_source` files are parsed for reusable standard-text snippets.
model Template {
  id            String   @id @default(cuid())
  name          String
  kind          String // 'docx_template' | 'text_source'
  docType       String // 'docx' | 'pptx'
  category      String? // deliverable type or section id this template targets
  fileUrl       String
  fileName      String
  mimeType      String
  fileSize      Int
  extractedText String? // full text (text_source) for the snippet browser
  snippets      Json? // [{ heading, text }] parsed from the upload
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String

  @@index([kind])
}

/// Workspace-wide branding & general settings (single row, id = "singleton").
model BrandingSettings {
  id                 String   @id
  companyName        String   @default("Arcwide")
  logoUrl            String?
  defaultCurrency    String   @default("EUR")
  validityDays       Int      @default(90)
  footerText         String   @default("ARCWIDE · IFS CLOUD IMPLEMENTATION PROPOSAL")
  templateSelections Json? // { estimate?: templateId, pricing?: templateId, proposal?: templateId }
  updatedAt          DateTime @updatedAt
}

/// Global default proposal content (single row, id = "singleton"), seeded from
/// static-content.ts. Editable by admins via the proposal builder.
model ProposalDefaults {
  id                  String   @id
  raci                Json
  crims               Json
  methodologyPhases   Json
  waysOfWorking       Json
  governance          Json
  // Nullable so the column can be added without a destructive migration; the
  // resolve cascade falls back to the built-in default when absent.
  teamStructure       Json?
  customerCommitments Json
  dataMigrationSteps  Json
  integrationSteps    Json
  testingSteps        Json
  adoptionSteps       Json
  goLiveSteps         Json
  whyArcwide          Json
  updatedAt           DateTime @updatedAt
}

/// A named, workspace-wide deck template (e.g. "Standard Arcwide deck"). Scoped to
/// one output kind. Holds an ordered set of immutable versions; one is the default.
model DeckTemplate {
  id                 String                @id @default(cuid())
  name               String
  description        String?
  kind               String // 'full_proposal' | 'board_summary'
  isWorkspaceDefault Boolean               @default(false)
  defaultVersionId   String?               @unique
  defaultVersion     DeckTemplateVersion?  @relation("DefaultVersion", fields: [defaultVersionId], references: [id], onDelete: SetNull)
  versions           DeckTemplateVersion[] @relation("TemplateVersions")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String

  @@index([kind])
}

/// An immutable snapshot of a deck's editable content layer: structured blocks,
/// narrative defaults, section on/off selection, and branding overrides. Editing a
/// template always creates a new version.
model DeckTemplateVersion {
  id         String       @id @default(cuid())
  templateId String
  template   DeckTemplate @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  version    Int
  label      String?

  // Structured blocks (always complete — same shape as ProposalDefaults).
  raci                Json
  crims               Json
  methodologyPhases   Json
  waysOfWorking       Json
  governance          Json
  teamStructure       Json?
  customerCommitments Json
  dataMigrationSteps  Json
  integrationSteps    Json
  testingSteps        Json
  adoptionSteps       Json
  goLiveSteps          Json
  whyArcwide          Json

  // Narrative defaults (null => no template-level narrative for that field).
  executiveSummary Json?
  understanding    String?
  valueDrivers     Json?
  commercialModel  String?
  recommendation   String?
  teamProfiles     Json?
  references       Json?
  contactName      String?
  contactTitle     String?
  contactEmail     String?
  contactPhone     String?

  // Section on/off selection, e.g. { executive_summary: true, raci: false }.
  sectionSelection Json

  // Branding overrides (null => fall back to BrandingSettings singleton).
  companyName String?
  footerText  String?

  defaultFor          DeckTemplate?     @relation("DefaultVersion")
  fullDeckSelections  ProposalContent[] @relation("FullDeckSelection")
  boardDeckSelections ProposalContent[] @relation("BoardDeckSelection")
  createdAt           DateTime          @default(now())
  createdBy           String

  @@unique([templateId, version])
  @@index([templateId])
}

/// An uploaded .potx PowerPoint template used in REPLACE mode: generation composes
/// the output deck from this file's slides (mapped per section) instead of the
/// code-drawn pptxgenjs deck. The stored file is the NORMALIZED buffer (its main
/// part rewritten to ...presentation.main+xml so docxtemplater/automizer accept it).
model PptxDeckTemplate {
  id            String   @id @default(cuid())
  name          String
  deckKind      String // 'full_proposal' | 'board_summary'
  isActive      Boolean  @default(false) // the active template for deckKind (replace mode)

  fileUrl       String
  fileName      String
  mimeType      String
  fileSize      Int
  wasNormalized Boolean  @default(false) // true if a .potx content-type was rewritten

  // Parsed slide inventory: [{ index, title, tokens: string[], hasTable: boolean }]
  slides  Json
  // { sectionMap: { [sectionId]: slideIndex }, genericSlides: [{ slideIndex, position }], visualSplice: string[] }
  mapping Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  @@index([deckKind])
}
